4. .model small
.stack 100h
.data
    msg1 db 'Enter first number: $'
    msg2 db 13,10,'Enter second number: $'
    msg3 db 13,10,'Enter third number: $'
    msg4 db 13,10,'Biggest number is: $'

    n1 db ?
    n2 db ?
    n3 db ?
    max db ?

.code
main proc
    mov ax, @data
    mov ds, ax

    ; Input first number
    lea dx, msg1
    mov ah, 09h
    int 21h

    mov ah, 01h
    int 21h
    sub al, 30h
    mov n1, al

    ; Input second number
    lea dx, msg2
    mov ah, 09h
    int 21h

    mov ah, 01h
    int 21h
    sub al, 30h
    mov n2, al

    ; Input third number
    lea dx, msg3
    mov ah, 09h
    int 21h

    mov ah, 01h
    int 21h
    sub al, 30h
    mov n3, al

    ;  Find biggest number 
    mov al, n1
    mov max, al

    mov al, n2
    cmp al, max
    jle check_third
    mov max, al

check_third:
    mov al, n3
    cmp al, max
    jle show_result
    mov max, al

show_result:
    ;  Display result 
    lea dx, msg4
    mov ah, 09h
    int 21h

    mov dl, max
    add dl, 30h
    mov ah, 02h
    int 21h

    ;  Exit
    mov ah, 4Ch
    int 21h
main endp
end main
