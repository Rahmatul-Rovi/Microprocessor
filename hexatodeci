.model small 
.stack 100h
.data
FIN DB "Please input a hexadecimal number between A-F: $"
OL DB 0ah, 0dh, "Equivalent decimal number is: 1$"
.code
main proc
    mov ax, @data
    mov ds, ax
    LEA dx, FIN
    mov ah, 9
    int 21h
    mov ah,1
    int 21h
    
    mov bl,al
    LEA dx, OL
    mov ah, 9
    int 21h
    SUB bl,11h
    
    mov dl, bl
    mov ah,2
    int 21h
    
    main endp
end main
